{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "~/*": [
                "./src/*"
            ]
        },
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2021",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "node",
        "importHelpers": true,
        "isolatedModules": true,
        "strictNullChecks": true,
        "allowSyntheticDefaultImports": true,
        "lib": [
            "DOM",
            "ES5",
            "ES6",
            "ES7",
            "ES2021"
        ],
        "jsx": "react-jsx"
    },
    "include": [
        "**/*.js",
        "**/*.ts",
        "**/*.tsx",
        "**/*.jsx"
    ],
    "exclude": [
        "node_modules",
        "document"
    ]
}