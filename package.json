{
    "name": "obsidian-i18n",
    "version": "2.0.17",
    "description": "Obsidian国际化翻译插件，提供多语言支持和翻译管理功能",
    "main": "main.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:js\" \"npm run dev:css\"",
        "dev:js": "node esbuild.config.mjs",
        "dev:css": "npx @tailwindcss/cli -i ./src/styles.css -o ./styles.css --watch",
        "typecheck": "tsc -noEmit -skipLibCheck",
        "build": "npm run typecheck && npm run build:css && npm run build:js",
        "build:js": "node esbuild.config.mjs production",
        "build:css": "npx @tailwindcss/cli -i ./src/styles.css -o ./styles.css --minify",
        "version:bump": "node version-bump.mjs",
        "install:deps": "npm install",
        "clean:install": "rm -rf node_modules && npm install"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@tailwindcss/cli": "^4.1.16",
        "@types/babel__generator": "^7.27.0",
        "@types/babel__traverse": "^7.28.0",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^16.11.6",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "@typescript-eslint/eslint-plugin": "5.29.0",
        "@typescript-eslint/parser": "5.29.0",
        "builtin-modules": "3.3.0",
        "concurrently": "^9.2.1",
        "esbuild": "0.17.3",
        "obsidian": "latest",
        "tailwindcss": "^4.1.16",
        "tslib": "2.8.1",
        "typescript": "latest"
    },
    "dependencies": {
        "@babel/generator": "^7.28.5",
        "@babel/parser": "^7.28.5",
        "@babel/traverse": "^7.28.5",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-hover-card": "^1.1.15",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-progress": "^1.1.7",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.13.21",
        "@types/nanoid": "^2.1.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "fs-extra": "^11.3.2",
        "i18next": "^25.7.2",
        "lucide-react": "^0.545.0",
        "nanoid": "^5.1.6",
        "next-themes": "^0.4.6",
        "openai": "^6.7.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-i18next": "^16.5.0",
        "react-markdown": "^10.1.0",
        "react-resizable-panels": "^3.0.6",
        "remark-gfm": "^4.0.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.3.1",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.1.13",
        "zustand": "^5.0.8"
    }
}